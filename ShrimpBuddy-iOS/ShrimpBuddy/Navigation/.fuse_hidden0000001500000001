struct SamplingMenuView: View {
    enum SamplingTab: String, CaseIterable {
        case summary  = "Summary"
        case logs     = "Sampling Log"
    }

    @EnvironmentObject var authState: AuthStateObject

    @State private var activeTab: SamplingTab   = .summary
    @State private var sections: [FarmSection]  = []
    @State private var ponds: [Pond]            = []
    @State private var allLogs: [SamplingLog]   = []
    @State private var isLoading                = true
    @State private var showAddLog               = false

    // Filters
    @State private var selectedSectionId: String = ""
    @State private var selectedPondId: String?   = nil
    @State private var filterDate: Date?         = nil

    var isAdmin: Bool { TokenStore.shared.isAdmin }

    var pondsInSection: [Pond] {
        selectedSectionId.isEmpty ? ponds : ponds.filter { $0.sectionId == selectedSectionId }
    }
    var selectedPondName: String {
        guard let pid = selectedPondId else { return "All Ponds" }
        return ponds.first(where: { $0.id == pid })?.name ?? "All Ponds"
    }

    var filteredLogs: [SamplingLog] {
        allLogs.filter { log in
            // Section filter
            if !selectedSectionId.isEmpty {
                guard log.sectionId == selectedSectionId ||
                      ponds.first(where: { $0.id == log.pondId })?.sectionId == selectedSectionId
                else { return false }
            }
            // Pond filter
            if let pid = selectedPondId { guard log.pondId == pid else { return false } }
            // Date filter
            if let fd = filterDate {
                let day = Calendar.current.startOfDay(for: fd)
                let fmt = DateFormatter(); fmt.dateFormat = "yyyy-MM-dd"
                guard let logDate = (log.date.map { fmt.date(from: String($0.prefix(10))) } ?? nil),
                      Calendar.current.startOfDay(for: logDate) == day
                else { return false }
            }
            return true
        }
    }

    // Summary: latest log per pond (respects section + pond filter)
    var summaryItems: [(pond: Pond, log: SamplingLog?)] {
        let visiblePonds = selectedPondId != nil
            ? pondsInSection.filter { $0.id == selectedPondId }
            : pondsInSection
        return visiblePonds.map { pond in
            let latest = allLogs
                .filter { $0.pondId == pond.id }
                .sorted { ($0.date ?? "") > ($1.date ?? "") }
                .first
            return (pond, latest)
        }
    }

    var body: some View {
        VStack(spacing: 0) {
            SBAppHeader(title: "Sampling",
                        trailingAction: { showAddLog = true }, trailingLabel: "+ Sample")

            // Tab picker
            Picker("Tab", selection: $activeTab) {
                ForEach(SamplingTab.allCases, id: \.self) { tab in Text(tab.rawValue).tag(tab) }
            }
            .pickerStyle(.segmented)
            .padding(.horizontal, 14).padding(.vertical, 10)
            .background(Color.sbBg)
            .overlay(Divider().background(Color.sbOutline), alignment: .bottom)
            .onAppear { applySegmentedAppearance() }

            // Section filter (always visible)
            if sections.count > 1 {
                Picker("Section", selection: $selectedSectionId) {
                    ForEach(sections) { sec in Text(sec.name).tag(sec.id) }
                }
                .pickerStyle(.segmented)
                .padding(.horizontal, 14).padding(.vertical, 10)
                .background(Color.sbBg)
                .overlay(Divider().background(Color.sbOutline), alignment: .bottom)
                .onChange(of: selectedSectionId) { _ in selectedPondId = nil }
            }

            // Pond + Date filter (both tabs)
            HStack(spacing: 10) {
                Menu {
                    Button { selectedPondId = nil } label: {
                        HStack {
                            Text("All Ponds")
                            if selectedPondId == nil { Spacer(); Image(systemName: "checkmark") }
                        }
                    }
                    if !pondsInSection.isEmpty { Divider() }
                    ForEach(pondsInSection) { pond in
                        Button { selectedPondId = pond.id } label: {
                            HStack {
                                Text(pond.name)
                                if selectedPondId == pond.id { Spacer(); Image(systemName: "checkmark") }
                            }
                        }
                    }
                } label: {
                    HStack(spacing: 6) {
                        Image(systemName: "water.waves").font(.system(size: 11)).foregroundColor(.sbPrimary)
                        Text(selectedPondName).font(.system(size: 12, weight: .medium)).foregroundColor(.sbOnSurface)
                        Image(systemName: "chevron.down").font(.system(size: 9, weight: .semibold)).foregroundColor(.sbOnSurfaceVariant)
                    }
                    .padding(.horizontal, 12).padding(.vertical, 7)
                    .background(Color.sbSurface).cornerRadius(10)
                    .overlay(RoundedRectangle(cornerRadius: 10).stroke(Color.sbOutline, lineWidth: 1))
                }
                Spacer()
                HStack(spacing: 4) {
                    Image(systemName: "calendar").font(.system(size: 11)).foregroundColor(.sbPrimary)
                    if let fd = filterDate {
                        DatePicker("", selection: Binding(get: { fd }, set: { filterDate = $0 }),
                                   in: ...Date(), displayedComponents: .date)
                            .datePickerStyle(.compact).labelsHidden().tint(.sbPrimary).fixedSize()
                        Button { filterDate = nil } label: {
                            Image(systemName: "xmark.circle.fill")
                                .font(.system(size: 13)).foregroundColor(.sbOnSurfaceVariant)
                        }
                    } else {
                        Button { filterDate = Date() } label: {
                            Text("All dates").font(.system(size: 12)).foregroundColor(.sbOnSurface)
                        }
                    }
                }
                .padding(.horizontal, 12).padding(.vertical, 7)
                .background(filterDate != nil ? Color.sbPrimary.opacity(0.08) : Color.sbSurface).cornerRadius(10)
                .overlay(RoundedRectangle(cornerRadius: 10).stroke(
                    filterDate != nil ? Color.sbPrimary : Color.sbOutline, lineWidth: 1))
            }
            .padding(.horizontal, 14).padding(.vertical, 8)
            .background(Color.sbBg)
            .overlay(Divider().background(Color.sbOutline), alignment: .bottom)

            // Content
            if isLoading {
                Spacer(); ProgressView().tint(.sbPrimary); Spacer()
            } else {
                TabView(selection: $activeTab) {
                    SamplingSummaryContent(items: summaryItems, allLogs: allLogs)
                        .tag(SamplingTab.summary)
                    SamplingLogContent(logs: filteredLogs, ponds: ponds, isAdmin: isAdmin,
                                       onRefresh: { Task { await loadAll() } })
                        .tag(SamplingTab.logs)
                }
                .tabViewStyle(.page(indexDisplayMode: .never))
                .animation(.easeInOut(duration: 0.2), value: activeTab)
            }
        }
        .background(Color.sbBg.ignoresSafeArea())
        .navigationBarHidden(true)
        .task { await loadAll() }
        .sheet(isPresented: $showAddLog) {
            LogSamplingSheet(pondId: selectedPondId ?? (pondsInSection.first?.id ?? ""))
        }
    }

    private func loadAll() async {
        async let s = APIService.shared.getSections()
        async let p = APIService.shared.getPonds()
        async let l = APIService.shared.getSamplingLogs()
        sections  = (try? await s) ?? []
        ponds     = (try? await p) ?? []
        allLogs   = (try? await l) ?? []
        if selectedSectionId.isEmpty, let first = sections.first { selectedSectionId = first.id }
        isLoading = false
    }
}

// Summary tab — latest ABW/survival/biomass/FCR per pond in section
private struct SamplingSummaryContent: View {
    let items: [(pond: Pond, log: SamplingLog?)]
    let allLogs: [SamplingLog]

    private func shortDate(_ s: String?) -> String {
        guard let s else { return "—" }
        let fmt = DateFormatter(); fmt.dateFormat = "yyyy-MM-dd"
        let out = DateFormatter(); out.dateFormat = "d MMM"
        return fmt.date(from: String(s.prefix(10))).map { out.string(from: $0) } ?? String(s.prefix(10))
    }

    private func prevLog(pondId: String, before current: SamplingLog) -> SamplingLog? {
        allLogs
            .filter { $0.pondId == pondId && ($0.date ?? "") < (current.date ?? "") }
            .sorted { ($0.date ?? "") > ($1.date ?? "") }
            .first
    }

    var body: some View {
        Group {
            if items.isEmpty {
                EmptyStateView(icon: "🔬", title: "No Ponds",
                               message: "Select a section to see pond summaries.")
            } else {
                ScrollView {
                    VStack(spacing: 10) {
                        ForEach(items, id: \.pond.id) { item in
                            SBCard {
                                VStack(alignment: .leading, spacing: 10) {
                                    // Header row
                                    HStack {
                                        VStack(alignment: .leading, spacing: 2) {
                                            Text(item.pond.name)
                                                .font(.system(size: 15, weight: .bold)).foregroundColor(.sbOnSurface)
                                            if let log = item.log {
                                                HStack(spacing: 6) {
                                                    Text("DOC \(log.doc ?? 0)")
                                                        .font(.system(size: 11)).foregroundColor(.sbOnSurfaceVariant)
                                                    Text("·").foregroundColor(.sbOnSurfaceDim)
                                                    Text(shortDate(log.date))
                                                        .font(.system(size: 11)).foregroundColor(.sbOnSurfaceVariant)
                                                    if let sc = log.sampleCount {
                                                        Text("· \(sc) samples")
                                                            .font(.system(size: 11)).foregroundColor(.sbOnSurfaceDim)
                                                    }
                                                }
                                            } else {
                                                Text("No samples yet")
                                                    .font(.system(size: 11)).foregroundColor(.sbOnSurfaceDim)
                                            }
                                        }
                                        Spacer()
                                        if let log = item.log {
                                            // ABW + growth delta badge
                                            VStack(alignment: .trailing, spacing: 2) {
                                                HStack(alignment: .firstTextBaseline, spacing: 3) {
                                                    Text(String(format: "%.1fg", log.abw ?? 0))
                                                        .font(.system(size: 18, weight: .bold)).foregroundColor(.sbPrimaryLight)
                                                    let delta: Double = {
                                                        if let gd = log.growthDiffG { return gd }
                                                        if let prev = prevLog(pondId: item.pond.id, before: log),
                                                           let pABW = prev.abw, let cABW = log.abw {
                                                            return cABW - pABW
                                                        }
                                                        return 0
                                                    }()
                                                    if delta != 0 {
                                                        Text(String(format: "%+.1fg", delta))
                                                            .font(.system(size: 10, weight: .semibold))
                                                            .foregroundColor(delta >= 0 ? .sbSuccess : .sbError)
                                                            .padding(.horizontal, 5).padding(.vertical, 2)
                                                            .background((delta >= 0 ? Color.sbSuccess : Color.sbError).opacity(0.12))
                                                            .cornerRadius(6)
                                                    }
                                                }
                                                Text("ABW").font(.system(size: 9)).foregroundColor(.sbOnSurfaceDim)
                                            }
                                        }
                                    }

                                    if let log = item.log {
                                        Divider().background(Color.sbOutline)

                                        // Metrics grid
                                        let survival = log.survivalPct ?? log.estimatedSurvival ?? 0
                                        let biomass  = log.biomassKg ?? 0
                                        let fcr      = log.fcr ?? 0
                                        let pop      = Int(log.estPopulation ?? 0)
                                        let seedCount = item.pond.seedCount ?? 0
                                        let estPop = pop > 0 ? pop : (seedCount > 0 ? Int(Double(seedCount) * survival / 100) : 0)

                                        LazyVGrid(columns: [
                                            GridItem(.flexible()), GridItem(.flexible()), GridItem(.flexible())
                                        ], spacing: 8) {
                                            SamplingMetricCell(
                                                label: "Survival",
                                                value: seedCount > 0 ? String(format: "%.1f%%", survival * (survival <= 1 ? 100 : 1)) : "—",
                                                color: survival >= 70 ? .sbSuccess : survival >= 50 ? .sbWarning : .sbError)
                                            SamplingMetricCell(
                                                label: "Biomass",
                                                value: biomass > 0 ? String(format: "%.1f kg", biomass) : "—",
                                                color: .sbPrimary)
                                            SamplingMetricCell(
                                                label: "FCR",
                                                value: fcr > 0 ? String(format: "%.2f", fcr) : "—",
                                                color: fcr > 0 && fcr <= 1.5 ? .sbSuccess : fcr <= 2.0 ? .sbWarning : .sbOnSurface)
                                            SamplingMetricCell(
                                                label: "Est. Pop.",
                                                value: estPop > 0 ? "\(estPop)" : "—",
                                                color: .sbOnSurface)
                                            SamplingMetricCell(
                                                label: "Seed Count",
                                                value: seedCount > 0 ? "\(seedCount)" : "—",
                                                color: .sbOnSurfaceVariant)
                                            SamplingMetricCell(
                                                label: "Cumul. Feed",
                                                value: (log.cumulFeedKg ?? 0) > 0 ? String(format: "%.1f kg", log.cumulFeedKg!) : "—",
                                                color: .sbOnSurfaceVariant)
                                        }
                                    }
                                }
                            }
                        }
                    }.padding(14)
                }
            }
        }.background(Color.sbBg.ignoresSafeArea())
    }
