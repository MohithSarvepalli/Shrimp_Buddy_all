private struct SettingsSection<Content: View>: View {
    let title: String; let content: Content
    init(title: String, @ViewBuilder content: () -> Content) {
        self.title = title; self.content = content()
    }
    var body: some View {
        VStack(alignment: .leading, spacing: 4) {
            Text(title.uppercased())
                .font(.system(size: 10, weight: .semibold))
                .foregroundColor(.sbOnSurfaceDim).kerning(0.8)
                .padding(.horizontal, 4).padding(.bottom, 2)
            VStack(spacing: 0) { content }
                .background(Color.sbSurface)
                .cornerRadius(14)
                .overlay(RoundedRectangle(cornerRadius: 14).stroke(Color.sbOutline, lineWidth: 0.8))
        }
    }
}

private struct SettingsInfoRow: View {
    let label: String; let value: String
    var body: some View {
        HStack {
            Text(label)
                .font(.system(size: 14, weight: .medium)).foregroundColor(.sbOnSurface)
            Spacer()
            Text(value)
                .font(.system(size: 13)).foregroundColor(.sbOnSurfaceVariant)
                .lineLimit(1).truncationMode(.middle)
        }
        .padding(.horizontal, 16).padding(.vertical, 13)
    }
}

private struct SettingsToggleRow: View {
    let label: String; let subtitle: String
    @Binding var isOn: Bool
    var body: some View {
        HStack(spacing: 12) {
            VStack(alignment: .leading, spacing: 2) {
                Text(label).font(.system(size: 14, weight: .medium)).foregroundColor(.sbOnSurface)
                Text(subtitle).font(.system(size: 11)).foregroundColor(.sbOnSurfaceVariant)
            }
            Spacer()
            Toggle("", isOn: $isOn).tint(.sbPrimary).labelsHidden()
        }
        .padding(.horizontal, 16).padding(.vertical, 12)
    }
}
