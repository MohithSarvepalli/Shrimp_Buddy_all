                    }
                    // New password
                    VStack(alignment: .leading, spacing: 5) {
                        Text("NEW PASSWORD").font(.system(size: 10, weight: .semibold))
                            .foregroundColor(.sbOnSurfaceVariant).kerning(0.6)
                        HStack {
                            Group {
                                if showNew { TextField("", text: $newPwd) }
                                else { SecureField("", text: $newPwd) }
                            }
                            .font(.system(size: 15)).foregroundColor(.sbOnSurface)
                            Button { showNew.toggle() } label: {
                                Image(systemName: showNew ? "eye.slash" : "eye")
                                    .foregroundColor(.sbOnSurfaceDim)
                            }
                        }
                        .padding(12)
                        .background(Color.sbSurface)
                        .cornerRadius(10)
                        .overlay(RoundedRectangle(cornerRadius: 10).stroke(Color.sbOutline, lineWidth: 0.8))
                    }
                    SBTextField(label: "Confirm New Password", text: $confirm,
                                placeholder: "", isSecure: true)
                    if let err = error {
                        Text(err).font(.system(size: 13)).foregroundColor(.sbError)
                    }
                    SBPrimaryButton("Update Password", isLoading: isLoading) {
                        Task {
                            guard newPwd.count >= 6 else {
                                error = "Password must be at least 6 characters"; return
                            }
                            guard newPwd == confirm else {
                                error = "Passwords don't match"; return
                            }
                            isLoading = true; error = nil
                            do {
                                try await APIService.shared.updateMyProfile(name: nil, password: newPwd)
                                await MainActor.run { dismiss() }
                            } catch {
                                await MainActor.run { self.error = error.localizedDescription }
                            }
                            isLoading = false
                        }
                    }
                    Spacer()
                }.padding(20)
            }
            .navigationTitle("Change Password").navigationBarTitleDisplayMode(.inline)
            .toolbar { ToolbarItem(placement: .navigationBarLeading) {
                Button("Cancel") { dismiss() }.foregroundColor(.sbPrimaryLight)
            }}
            .preferredColorScheme(.dark)
        }
    }
}

