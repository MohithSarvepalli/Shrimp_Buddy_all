private struct EditChemMasterSheet: View {
    let master: ChemicalInventoryItem
    var onSaved: () -> Void
    @Environment(\.dismiss) private var dismiss
    @State private var name: String
    @State private var category: String
    @State private var unit: String
    @State private var ratePerUnit: String
    @State private var isSaving = false
    @State private var errorMsg: String?

    init(master: ChemicalInventoryItem, onSaved: @escaping () -> Void) {
        self.master = master
        self.onSaved = onSaved
        _name        = State(initialValue: master.name)
        _category    = State(initialValue: master.category ?? "")
        _unit        = State(initialValue: master.unit)
        _ratePerUnit = State(initialValue: String(format: "%.2f", master.ratePerUnit))
    }
    var body: some View {
        NavigationView {
            Form {
                Section("Chemical Master") {
                    TextField("Name", text: $name)
                    TextField("Category", text: $category)
                    TextField("Unit", text: $unit)
                    TextField("Rate/Unit", text: $ratePerUnit).keyboardType(.decimalPad)
                }
                if let err = errorMsg {
                    Section { Text(err).foregroundColor(.red).font(.system(size: 12)) }
                }
            }
            .navigationTitle("Edit Chemical")
            .navigationBarTitleDisplayMode(.inline)
