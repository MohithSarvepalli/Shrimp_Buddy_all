    private func loadFarm() async {
        if let f = (try? await APIService.shared.getMyFarms())?.first {
            farm = f
            feedMode = f.feedManagementMode ?? "central_store"
            chemMode = f.chemManagementMode ?? "central_store"
        }
        isLoading = false
    }

    private func saveInventoryMode() async {
        guard let farmId = farm?.id else { return }
        isSaving = true; saveError = nil; saveSuccess = false
        do {
            let updated = try await APIService.shared.updateFarm(
                id: farmId,
                feedManagementMode: feedMode,
                chemicalManagementMode: chemMode
            )
            farm = updated
            saveSuccess = true
            DispatchQueue.main.asyncAfter(deadline: .now() + 2) { saveSuccess = false }
        } catch {
            saveError = "Save failed: \(error.localizedDescription)"
        }
        isSaving = false
    }
}

