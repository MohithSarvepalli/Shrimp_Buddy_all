private struct EditSamplingLogSheet: View {
    let log: SamplingLog
    var onSaved: () -> Void
    @Environment(\.dismiss) private var dismiss
    @State private var date: Date
    @State private var abw: String
    @State private var survivalPct: String
    @State private var sampleCount: String
    @State private var doc: String
    @State private var isSaving = false
    @State private var errorMsg: String?

    init(log: SamplingLog, onSaved: @escaping () -> Void) {
        self.log = log
        self.onSaved = onSaved
        let df = DateFormatter(); df.dateFormat = "yyyy-MM-dd"
        let d = log.date.flatMap { df.date(from: String($0.prefix(10))) } ?? Date()
        _date        = State(initialValue: d)
        _abw         = State(initialValue: log.abw.map { String(format: "%.2f", $0) } ?? "")
        _survivalPct = State(initialValue: (log.survivalPct ?? log.estimatedSurvival).map { String(format: "%.1f", $0) } ?? "")
        _sampleCount = State(initialValue: log.sampleCount.map { String($0) } ?? "")
        _doc         = State(initialValue: log.doc.map { String($0) } ?? "")
    }

    var body: some View {
        NavigationView {
            Form {
                Section("Sample Data") {
                    DatePicker("Date", selection: $date, in: ...Date(), displayedComponents: .date)
                    TextField("ABW (g)", text: $abw).keyboardType(.decimalPad)
                    TextField("Survival %", text: $survivalPct).keyboardType(.decimalPad)
                    TextField("Sample Count", text: $sampleCount).keyboardType(.numberPad)
                    TextField("DOC", text: $doc).keyboardType(.numberPad)
                }
                if let err = errorMsg {
                    Section { Text(err).foregroundColor(.red).font(.system(size: 12)) }
                }
            }
            .navigationTitle("Edit Sample")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .cancellationAction) { Button("Cancel") { dismiss() } }
                ToolbarItem(placement: .confirmationAction) {
                    Button("Save") { Task { await save() } }.disabled(isSaving)
                }
            }
            .overlay { if isSaving { ProgressView().frame(maxWidth: .infinity, maxHeight: .infinity).background(Color.black.opacity(0.15)) } }
        }
    }

    private func save() async {
        isSaving = true; defer { isSaving = false }
        let df = DateFormatter(); df.dateFormat = "yyyy-MM-dd"
        let body = UpdateSamplingRequest(
            date: df.string(from: date),
            abw: Double(abw),
            survivalPct: Double(survivalPct),
            sampleCount: Int(sampleCount),
            doc: Int(doc),
            notes: nil
        )
        do {
            _ = try await APIService.shared.updateSamplingLog(id: log.id, body)
            onSaved()
        } catch { errorMsg = "Save failed: \(error.localizedDescription)" }
    }
}

