private struct ChemCentralContent: View {
    let dispatches: [ChemicalDispatchRecord]
    let logs: [ChemicalLog]
    let sections: [FarmSection]
    var masters: [ChemicalInventoryItem] = []
    var isAdmin: Bool = false
    var onRefresh: (() -> Void)? = nil

    struct Balance: Identifiable {
        let id: String; let sectionName: String; let chemName: String
        let dispatched: Double; let used: Double; let unit: String
        var balance: Double { dispatched - used }
    }

    var balances: [Balance] {
        var dispMap: [String: [String: (Double, String)]] = [:]
        for d in dispatches {
            let sid = d.sectionId ?? ""; guard !sid.isEmpty else { continue }
            let key = d.chemicalName.lowercased()
            var inner = dispMap[sid] ?? [:]
            let prev = inner[key] ?? (0, d.unit)
            inner[key] = (prev.0 + d.qtyDispatched, d.unit)
            dispMap[sid] = inner
        }
        var result: [Balance] = []
        for (sid, chems) in dispMap {
            let secName = sections.first(where: { $0.id == sid })?.name ?? sid
            for (name, (qty, unit)) in chems {
                let used = logs.filter { ($0.chemicalName ?? $0.name ?? "").lowercased() == name }
                               .reduce(0.0) { $0 + ($1.qty ?? $1.quantity ?? 0) }
                result.append(Balance(id: sid+name, sectionName: secName,
                                      chemName: name.capitalized, dispatched: qty, used: used, unit: unit))
            }
        }
        return result.sorted { $0.sectionName < $1.sectionName }
    }

    var body: some View {
        Group {
            if balances.isEmpty {
                EmptyStateView(icon: "🏭", title: "No Central Inventory",
                               message: "Central stock appears after dispatches are recorded.")
            } else {
                ScrollView {
                    VStack(spacing: 8) {
                        ForEach(balances) { b in
                            ChemCentralBalanceCard(
                                balance: b,
                                master: masters.first(where: { $0.name.lowercased() == b.chemName.lowercased() }),
                                isAdmin: isAdmin,
                                onRefresh: onRefresh
                            )
                        }
                    }.padding(14)
                }
            }
        }.background(Color.sbBg.ignoresSafeArea())
    }
}

