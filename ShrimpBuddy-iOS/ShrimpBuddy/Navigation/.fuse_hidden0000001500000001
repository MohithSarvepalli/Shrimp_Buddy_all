// MARK: - Chemical Menu (unified view with shared filters)
struct ChemicalMenuView: View {
    enum ChemTab: String, CaseIterable {
        case central   = "Central Inv."
        case inventory = "Inventory"
        case dispatch  = "Dispatch"
        case usageLog  = "Usage Log"
    }

    @EnvironmentObject var authState: AuthStateObject

    // Shared state
    @State private var activeTab: ChemTab      = .central
    @State private var sections: [FarmSection] = []
    @State private var ponds: [Pond]           = []
    @State private var allLogs: [ChemicalLog]  = []
    @State private var allDispatches: [ChemicalDispatchRecord] = []
    @State private var inventoryItems: [ChemicalInventoryItem] = []
    @State private var chemBalance: [ChemicalBalanceItem] = []
    @State private var farm: FarmResponse?     = nil
    @State private var isLoading               = true

    // Shared filters
    @State private var selectedSectionId: String  = ""
    @State private var selectedPondId: String?    = nil
    @State private var filterDate: Date?          = nil

    var isCentral: Bool { farm?.chemManagementMode?.lowercased().contains("central") == true }
    var visibleTabs: [ChemTab] { isCentral ? ChemTab.allCases : ChemTab.allCases.filter { $0 != .central } }

    var pondsInSection: [Pond] {
        selectedSectionId.isEmpty ? ponds : ponds.filter { $0.sectionId == selectedSectionId }
    }
    var selectedPondName: String {
        guard let pid = selectedPondId else { return "All Ponds" }
        return ponds.first(where: { $0.id == pid })?.name ?? "All Ponds"
    }
    var filterDay: Date? { filterDate.map { Calendar.current.startOfDay(for: $0) } }

    // Inventory tab: scoped to selected section
    var inventoryDispatches: [ChemicalDispatchRecord] {
        selectedSectionId.isEmpty ? allDispatches
            : allDispatches.filter { $0.sectionId == selectedSectionId }
    }
    var inventoryLogs: [ChemicalLog] {
        guard !selectedSectionId.isEmpty else { return allLogs }
        let sectionPondIds = Set(ponds.filter { $0.sectionId == selectedSectionId }.map { $0.id })
        // Include logs from ponds in section + logs from ponds with no section mapping (e.g. C1, C9)
        return allLogs.filter { log in
            let pond = ponds.first(where: { $0.id == log.pondId })
            return pond == nil || sectionPondIds.contains(log.pondId)
        }
    }

    var filteredLogs: [ChemicalLog] {
        allLogs.filter { log in
            if !selectedSectionId.isEmpty {
                // ChemicalLog has no sectionId; filter by matching pond's section
                let pond = ponds.first(where: { $0.id == log.pondId })
                if pond?.sectionId != selectedSectionId { return false }
            }
            if let pid = selectedPondId, log.pondId != pid { return false }
            if let fd = filterDay,
               let d = parseChemDate(log.date), d < fd { return false }
            return true
        }.sorted { ($0.date ?? "") > ($1.date ?? "") }
    }

    var filteredDispatches: [ChemicalDispatchRecord] {
        allDispatches.filter { d in
            if !selectedSectionId.isEmpty, d.sectionId != selectedSectionId { return false }
            if let fd = filterDay,
               let dd = parseChemDate(d.date), dd < fd { return false }
            return true
        }.sorted { $0.date > $1.date }
    }

    var body: some View {
        VStack(spacing: 0) {
            SBAppHeader(title: "Chemicals")

            // ── Tab picker ──────────────────────────────────────────────────
            Picker("", selection: $activeTab) {
                ForEach(visibleTabs, id: \.self) { Text($0.rawValue).tag($0) }
            }
            .pickerStyle(.segmented)
            .padding(.horizontal, 14).padding(.vertical, 10)
            .overlay(Divider().background(Color.sbOutline), alignment: .bottom)
            .onAppear { applySegmentedAppearance() }

            // ── Section picker — all tabs except Central Inventory (which is always farm-wide)
            if sections.count > 1 && activeTab != .central {
                Picker("Section", selection: $selectedSectionId) {
                    ForEach(sections) { sec in Text(sec.name).tag(sec.id) }
                }
                .pickerStyle(.segmented)
                .padding(.horizontal, 14).padding(.vertical, 10)
                .background(Color.sbBg)
                .overlay(Divider().background(Color.sbOutline), alignment: .bottom)
                .onChange(of: selectedSectionId) { _ in selectedPondId = nil }
            }

            // ── Pond + Date filter row ───────────────────────────────────────
            if activeTab == .usageLog || activeTab == .dispatch {
                HStack(spacing: 10) {
                    // Pond dropdown
                    Menu {
                        Button { selectedPondId = nil } label: {
                            HStack { Text("All Ponds"); if selectedPondId == nil { Spacer(); Image(systemName: "checkmark") } }
                        }
                        if !pondsInSection.isEmpty { Divider() }
                        ForEach(pondsInSection) { pond in
                            Button { selectedPondId = pond.id } label: {
                                HStack { Text(pond.name); if selectedPondId == pond.id { Spacer(); Image(systemName: "checkmark") } }
                            }
                        }
                    } label: {
                        HStack(spacing: 6) {
                            Image(systemName: "water.waves").font(.system(size: 11)).foregroundColor(.sbPrimary)
                            Text(selectedPondName).font(.system(size: 12, weight: .medium)).foregroundColor(.sbOnSurface)
                            Image(systemName: "chevron.down").font(.system(size: 9, weight: .semibold)).foregroundColor(.sbOnSurfaceVariant)
                        }
                        .padding(.horizontal, 12).padding(.vertical, 7)
                        .background(Color.sbSurface).cornerRadius(10)
                        .overlay(RoundedRectangle(cornerRadius: 10).stroke(Color.sbOutline, lineWidth: 1))
                    }
                    Spacer()
                    // Date filter
                    HStack(spacing: 4) {
                        Image(systemName: "calendar").font(.system(size: 11)).foregroundColor(.sbPrimary)
                        if let fd = filterDate {
                            DatePicker("", selection: Binding(get: { fd }, set: { filterDate = $0 }),
                                       in: ...Date(), displayedComponents: .date)
                                .datePickerStyle(.compact).labelsHidden().tint(.sbPrimary).fixedSize()
                            Button { filterDate = nil } label: {
                                Image(systemName: "xmark.circle.fill")
                                    .font(.system(size: 13)).foregroundColor(.sbOnSurfaceVariant)
                            }
                        } else {
                            Button { filterDate = Date() } label: {
                                Text("All dates").font(.system(size: 12)).foregroundColor(.sbOnSurface)
                            }
                        }
                    }
                    .padding(.horizontal, 12).padding(.vertical, 7)
                    .background(filterDate != nil ? Color.sbPrimary.opacity(0.08) : Color.sbSurface).cornerRadius(10)
                    .overlay(RoundedRectangle(cornerRadius: 10).stroke(
                        filterDate != nil ? Color.sbPrimary : Color.sbOutline, lineWidth: 1))
                }
                .padding(.horizontal, 14).padding(.vertical, 8)
                .background(Color.sbBg)
                .overlay(Divider().background(Color.sbOutline), alignment: .bottom)
            }

            // ── Content ─────────────────────────────────────────────────────
            if isLoading {
                Spacer(); ProgressView().tint(.sbPrimary); Spacer()
            } else {
                TabView(selection: $activeTab) {
                    ChemCentralContent(
                        dispatches: allDispatches,
                        logs: allLogs,
                        sections: sections,
                        masters: inventoryItems,
                        isAdmin: {
                            let r = (TokenStore.shared.role ?? authState.currentUser?.role ?? "").uppercased()
                            return r == "OWNER" || r == "ADMIN"
                        }(),
                        onRefresh: { Task { await loadAll() } }
                    )
                    .tag(ChemTab.central)
                    ChemInventoryContent(
                        dispatches: inventoryDispatches,
                        logs: inventoryLogs,
                        masters: inventoryItems,
                        isAdmin: {
                            let r = (TokenStore.shared.role ?? authState.currentUser?.role ?? "").uppercased()
                            return r == "OWNER" || r == "ADMIN"
                        }(),
                        onRefresh: { Task { await loadAll() } }
                    ).tag(ChemTab.inventory)
                    ChemDispatchContent(
                        dispatches: filteredDispatches,
                        sections: sections,
                        isAdmin: {
                            let r = (TokenStore.shared.role ?? authState.currentUser?.role ?? "").uppercased()
                            return r == "OWNER" || r == "ADMIN"
                        }(),
                        onRefresh: { Task { await loadAll() } }
                    )
                    .tag(ChemTab.dispatch)
                    ChemUsageContent(
                        logs: filteredLogs,
                        ponds: ponds,
                        isAdmin: {
                            let r = (TokenStore.shared.role ?? authState.currentUser?.role ?? "").uppercased()
                            return r == "OWNER" || r == "ADMIN"
                        }(),
                        onRefresh: { Task { await loadAll() } }
                    )
                    .tag(ChemTab.usageLog)
                }
                .tabViewStyle(.page(indexDisplayMode: .never))
                .animation(.easeInOut(duration: 0.2), value: activeTab)
            }
        }
        .background(Color.sbBg.ignoresSafeArea())
        .navigationBarHidden(false)
        .task { await loadAll() }
        .onChange(of: selectedSectionId) { _ in
            // auto-select first section on load
        }
    }

    private func loadAll() async {
        isLoading = true
        async let s  = APIService.shared.getSections()
        async let p  = APIService.shared.getPonds()
        async let l  = APIService.shared.getChemicalLogs()
        async let d  = APIService.shared.getChemicalDispatches()
        async let iv = APIService.shared.getChemicalInventory()
        async let cb = APIService.shared.getChemicalBalance()
        async let f  = APIService.shared.getMyFarms()
        sections         = (try? await s)  ?? []
        ponds            = (try? await p)  ?? []
        allLogs          = (try? await l)  ?? []
        allDispatches    = (try? await d)  ?? []
        inventoryItems   = (try? await iv) ?? []
        chemBalance      = (try? await cb) ?? []
        farm             = (try? await f)?.first
        if selectedSectionId.isEmpty, let first = sections.first {
            selectedSectionId = first.id
        }
        isLoading = false
    }

    private func parseChemDate(_ s: String?) -> Date? {
        guard let s else { return nil }
        let f = DateFormatter(); f.dateFormat = "yyyy-MM-dd"
        return f.date(from: String(s.prefix(10)))
    }
}

// Sub-content views (stateless — receive filtered data from parent)

private struct ChemInventoryContent: View {
    // Always uses section-filtered dispatches + logs for accuracy
    let dispatches: [ChemicalDispatchRecord]
    let logs: [ChemicalLog]
    let masters: [ChemicalInventoryItem]
    var isAdmin: Bool = false
    var onRefresh: (() -> Void)? = nil

    var displayItems: [ChemicalBalanceItem] {
        var dispMap: [String: (name: String, unit: String, qty: Double)] = [:]
        for d in dispatches {
            let key = d.chemicalName.lowercased()
            var e = dispMap[key] ?? (d.chemicalName, d.unit, 0)
            e.qty += d.qtyDispatched
            dispMap[key] = e
        }
        var usedMap: [String: Double] = [:]
        for l in logs {
            let key = (l.chemicalName ?? l.name ?? "").lowercased()
            guard !key.isEmpty else { continue }
            usedMap[key, default: 0] += l.qty ?? l.quantity ?? 0
        }
        return dispMap.compactMap { key, val in
            let used = usedMap[key] ?? 0
            let balance = val.qty - used
            guard val.qty > 0 && balance > 0.001 else { return nil }  // skip never-dispatched and fully-used
            return ChemicalBalanceItem(
                chemicalName: val.name, unit: val.unit, category: nil,
                received: val.qty, dispatched: val.qty, used: used,
                centralBalance: 0, sectionBalance: max(0, balance)
            )
        }
        .sorted { $0.chemicalName < $1.chemicalName }
    }

    var body: some View {
        Group {
            if displayItems.isEmpty {
                EmptyStateView(icon: "🧪", title: "No Inventory",
                               message: "Record chemical dispatches to see stock balances.")
            } else {
                ScrollView {
                    VStack(spacing: 8) {
                        ForEach(displayItems) { b in
                            ChemBalanceCard(
                                item: b,
                                master: masters.first(where: {
                                    $0.name.lowercased() == b.chemicalName.lowercased()
                                }),
                                isAdmin: isAdmin,
                                onRefresh: onRefresh
                            )
                        }
                    }.padding(14)
                }
            }
        }.background(Color.sbBg.ignoresSafeArea())
    }
}

