                            SettingsInfoRow(label: "Farm ID", value: farm?.id ?? "—")
                            Divider().background(Color.sbOutline).padding(.leading, 16)
                            SettingsInfoRow(label: "Role",
                                           value: (TokenStore.shared.role ?? farm?.role ?? "—").capitalized)
                        }

                        // ── Inventory Model (admin only) ──────────────────────
                        if isAdmin {
                        SettingsSection(title: "Inventory Model") {
                            VStack(alignment: .leading, spacing: 10) {
                                Text("Feed Management")
